<?xml version="1.0"?>
<sdf version="1.6">
  <world name="training_env_world">

    <!-- ROS state plugin: enables /gazebo/set_model_state, get_model_state -->
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros>
        <namespace>/gazebo</namespace>
        <argument>--ros-args --remap model_states:=model_states_gazebo</argument>
        <argument>--ros-args --remap link_states:=link_states_gazebo</argument>
      </ros>
      <update_rate>100.0</update_rate>
    </plugin>

    <!-- Ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- Sun light -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- Scene settings -->
    <scene>
      <shadows>false</shadows>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
    </scene>

    <!-- Camera view (top-down, centered on training env) -->
    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose frame=''>0.0 0.0 30.0 0 1.5708 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <!-- Physics settings (same as td7_static.world) -->
    <physics type="ode">
      <real_time_update_rate>1000.0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!--
      Blender Training Environment
      Includes walls and floor layout from Blender design.
      The model.sdf applies roll=+90° to convert OBJ Y-up → Gazebo Z-up.
    -->
    <include>
      <uri>model://training_env</uri>
      <name>training_env</name>
      <pose>0 0 0 0 0 0</pose>
      <static>true</static>
    </include>

  </world>
</sdf>
